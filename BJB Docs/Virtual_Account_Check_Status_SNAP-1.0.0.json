              "example": {
                "partnerServiceId": "   18123",
                "customerNo": "000020000000869",
                "virtualAccountNo": "   18123000020000000869",
                "inquiryRequestId": "230921-100811-916614"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "X-PARTNER-ID": [],
            "OAUTH-SNAP-PARTNER": [
              "default"
            ]
          }
        ]
      }
    }
  },
