            "example": "0dfc9b5f9ad5770573cd42b525105996823dd4ac82bd0d03d94b5661e2ffc42eea0cd5b23498f20ec829d33f254abac6160ed2ff6c30e523f2f87143e85c2ab7"
          },
          {
            "name": "ORIGIN",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "wwww.bankbjb.co.id"
          },
          {
            "name": "X-EXTERNAL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 1704163477
          },
          {
            "name": "CHANNEL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 54321
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReqJSON"
