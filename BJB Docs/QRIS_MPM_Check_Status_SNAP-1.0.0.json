{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "QRIS MPM Check Status SNAP",
    "x-ibm-name": "qris-mpm-check-status-snap",
    "description": "API for QRIS Merchant Check Status SNAP"
  },
  "servers": [
    {
      "url": "https://devapi.bankbjb.co.id/v1.0/qr/qr-mpm-query"
    }
  ],
  "x-ibm-configuration": {
    "cors": {
      "enabled": false,
      "policy": []
    },
    "type": "rest",
    "phase": "realized",
    "enforced": true,
    "testable": true,
    "oauth-servers": {
      "OAUTH-SNAP-PARTNER": {
        "clientCredentials": {
          "tokenUrls": [
            "https://devapi.bankbjb.co.id/api/v1/access-token/b2b"
          ],
          "authorizationUrls": [],
          "refreshUrls": []
        }
      }
    }
  },
  "paths": {
    "/": {
      "post": {
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResJSON"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-TIMESTAMP",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "2024-03-08T10:55:00+07:00"
          },
          {
            "name": "X-SIGNATURE",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "0dfc9b5f9ad5770573cd42b525105996823dd4ac82bd0d03d94b5661e2ffc42eea0cd5b23498f20ec829d33f254abac6160ed2ff6c30e523f2f87143e85c2ab7"
          },
          {
            "name": "ORIGIN",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "www.bankbjb.co.id"
          },
          {
            "name": "X-EXTERNAL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 1704163477
          },
          {
            "name": "CHANNEL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 54321
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReqJSON"
              },
              "example": {
                "originalReferenceNo": "172459517125",
                "originalPartnerReferenceNo": "Test-Eliezer-0022",
                "serviceCode": "00",
                "merchantId": "457401354223872",
                "additionalInfo": {
                  "paymentId": "1",
                  "merchantCode": "628999999951",
                  "currency": "IDR"
                }
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "X-PARTNER-ID": [],
            "OAUTH-SNAP-PARTNER": [
              "default"
            ]
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "X-PARTNER-ID": {
        "type": "apiKey",
        "x-key-type": "client_id",
        "name": "X-PARTNER-ID",
        "in": "header"
      },
      "OAUTH-SNAP-PARTNER": {
        "type": "oauth2",
        "x-ibm-oauth-provider": "oauth2-snap-partner",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://devapi.bankbjb.co.id/api/v1/access-token/b2b",
            "scopes": {
              "default": "Default scope For Direct Debit SNAP REST API"
            }
          }
        }
      }
    },
    "schemas": {
      "ReqJSON": {
        "title": "ReqJSON",
        "type": "object",
        "description": "Request JSON QRIS MPM Check Status",
        "properties": {
          "originalReferenceNo": {
            "type": "string",
            "title": "originalReferenceNo"
          },
          "originalPartnerReferenceNo": {
            "type": "string",
            "title": "originalPartnerReferenceNo"
          },
          "serviceCode": {
            "type": "string",
            "title": "serviceCode"
          },
          "merchantId": {
            "type": "string",
            "title": "merchantId"
          },
          "additionalInfo": {
            "$ref": "#/components/schemas/additionalInfo",
            "title": "additionalInfo"
          }
        }
      },
      "additionalInfo": {
        "title": "additionalInfo",
        "type": "object",
        "description": "Additional Info QRIS MPM Check Status",
        "properties": {
          "PaymentId": {
            "type": "string",
            "title": "paymentId"
          },
          "MerchantCode": {
            "type": "string",
            "title": "merchantCode"
          },
          "Currency": {
            "type": "string",
            "title": "currency"
          },
          "Rrn": {
            "type": "string",
            "title": "transId"
          },
          "AuthCode": {
            "type": "string",
            "title": "authCode"
          },
          "ErrDesc": {
            "type": "string",
            "title": "errDesc"
          },
          "ErrorCode": {
            "type": "string",
            "title": "errorCode"
          }
        }
      },
      "ResJSON": {
        "title": "ResJSON",
        "type": "object",
        "description": "Response JSON QRIS MPM Check Status",
        "properties": {
          "responseCode": {
            "type": "string",
            "title": "responseCode"
          },
          "responseMessage": {
            "type": "string",
            "title": "responseMessage"
          },
          "originalReferenceNo": {
            "type": "string",
            "title": "originalReferenceNo"
          },
          "originalPartnerReferenceNo": {
            "type": "string",
            "title": "originalPartnerReferenceNo"
          },
          "serviceCode": {
            "type": "string",
            "title": "serviceCode"
          },
          "latestTransactionStatus": {
            "type": "string",
            "title": "latestTransactionStatus"
          },
          "transactionStatusDesc": {
            "type": "string",
            "title": "transactionStatusDesc"
          },
          "paidTime": {
            "type": "string",
            "title": "paidTime"
          },
          "amount": {
            "$ref": "#/components/schemas/amount",
            "title": "amount"
          },
          "feeAmount": {
            "$ref": "#/components/schemas/feeAmount",
            "title": "feeAmount"
          },
          "terminalId": {
            "type": "string",
            "title": "terminalId"
          },
          "additionalInfo": {
            "$ref": "#/components/schemas/additionalInfo",
            "title": "additionalInfo"
          }
        }
      },
      "amount": {
        "title": "amount",
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "title": "value"
          },
          "currency": {
            "type": "string",
            "title": "currency"
          }
        }
      },
      "feeAmount": {
        "title": "feeAmount",
        "type": "string",
        "properties": {
          "value": {
            "type": "string",
            "title": "value"
          },
          "currency": {
            "type": "string",
            "title": "currency"
          }
        }
      }
    }
  },
  "security": [
    {
      "X-PARTNER-ID": [],
      "OAUTH-SNAP-PARTNER": [
        "default"
      ]
    }
  ],
  "x-ibm-endpoints": [
    {
      "url": "https://devapi.bankbjb.co.id/v1.0/qr/qr-mpm-query"
    }
  ]
}