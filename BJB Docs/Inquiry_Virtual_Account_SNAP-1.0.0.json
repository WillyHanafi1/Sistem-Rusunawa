{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Inquiry Virtual Account SNAP",
    "x-ibm-name": "inquiry-virtual-account-snap",
    "description": "API for Inquiry Virtual Account BJB SNAP"
  },
  "servers": [
    {
      "url": "https://devapi.bankbjb.co.id/v1.0/transfer-va/inquiry-va"
    }
  ],
  "x-ibm-configuration": {
    "cors": {
      "enabled": false
    },
    "type": "rest",
    "phase": "realized",
    "enforced": true,
    "testable": true,
    "oauth-servers": {
      "OAUTH-SNAP-PARTNER": {
        "clientCredentials": {
          "tokenUrls": [
            "https://devapi.bankbjb.co.id/api/v1/access-token/b2b"
          ],
          "authorizationUrls": [],
          "refreshUrls": []
        }
      }
    }
  },
  "paths": {
    "/": {
      "post": {
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResJSON"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-TIMESTAMP",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "2024-03-08T10:55:00+07:00"
          },
          {
            "name": "X-SIGNATURE",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "0dfc9b5f9ad5770573cd42b525105996823dd4ac82bd0d03d94b5661e2ffc42eea0cd5b23498f20ec829d33f254abac6160ed2ff6c30e523f2f87143e85c2ab7"
          },
          {
            "name": "ORIGIN",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "www.bankbjb.co.id"
          },
          {
            "name": "X-EXTERNAL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 1704163477
          },
          {
            "name": "CHANNEL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 54321
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReqJSON"
              },
              "example": {
                "partnerServiceId": "   14848",
                "customerNo": "8390051583799999",
                "virtualAccountNo": "   14848390051583799999",
                "trxId": "TU1230"
              }
            }
          }
        },
        "security": [
          {
            "X-PARTNER-ID": [],
            "OAUTH-SNAP-PARTNER": [
              "default"
            ]
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "X-PARTNER-ID": {
        "type": "apiKey",
        "x-key-type": "client_id",
        "name": "X-PARTNER-ID",
        "in": "header"
      },
      "OAUTH-SNAP-PARTNER": {
        "type": "oauth2",
        "x-ibm-oauth-provider": "oauth2-snap-partner",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://devapi.bankbjb.co.id/api/v1/access-token/b2b",
            "scopes": {
              "default": "Default scope For Direct Debit SNAP REST API"
            }
          }
        }
      }
    },
    "schemas": {
      "ReqJSON": {
        "title": "ReqJSON",
        "type": "object",
        "description": "Request JSON API",
        "properties": {
          "partnerServiceId": {
            "type": "string",
            "title": "partnerServiceId"
          },
          "customerNo": {
            "type": "string",
            "title": "customerNo"
          },
          "virtualAccountNo": {
            "type": "string",
            "title": "virtualAccountNo"
          },
          "trxId": {
            "type": "string",
            "title": "trxId"
          }
        }
      },
      "ResJSON": {
        "title": "ResJSON",
        "type": "object",
        "description": "Response JSON API",
        "properties": {
          "responseCode": {
            "type": "string",
            "title": "responseCode"
          },
          "responseMessage": {
            "type": "string",
            "title": "responseMessage"
          },
          "virtualAccountData": {
            "$ref": "#/components/schemas/virtualAccountData",
            "title": "virtualAccountData"
          }
        }
      },
      "virtualAccountData": {
        "title": "virtualAccountData",
        "type": "object",
        "properties": {
          "partnerServiceId": {
            "type": "string",
            "title": "partnerServiceId"
          },
          "customerNo": {
            "type": "string",
            "title": "customerNo"
          },
          "virtualAccountNo": {
            "type": "string",
            "title": "virtualAccountNo"
          },
          "virtualAccountName": {
            "type": "string",
            "title": "virtualAccountName"
          },
          "trxId": {
            "type": "string",
            "title": "trxId"
          },
          "totalAmount": {
            "$ref": "#/components/schemas/totalAmount",
            "title": "totalAmount"
          },
          "expiredDate": {
            "type": "string",
            "title": "expiredDate"
          },
          "paymentDate": {
            "type": "string",
            "title": "paymentDate"
          },
          "additionalInfo": {
            "$ref": "#/components/schemas/additionalInfo",
            "title": "additionalInfo"
          }
        }
      },
      "totalAmount": {
        "title": "totalAmount",
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "title": "value"
          },
          "currency": {
            "type": "string",
            "title": "currency"
          }
        }
      },
      "additionalInfo": {
        "title": "additionalInfo",
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "title": "status"
          }
        }
      }
    }
  },
  "security": [
    {
      "X-PARTNER-ID": [],
      "OAUTH-SNAP-PARTNER": [
        "default"
      ]
    }
  ],
  "x-ibm-endpoints": [
    {
      "url": "https://devapi.bankbjb.co.id/v1.0/transfer-va/inquiry-va"
    }
  ]
}